# spec-forge UI — Environment Variables
# Copy this file to .env and configure your LLM provider

# LLM Provider: ollama | openai | anthropic | groq | gemini
LLM_PROVIDER=ollama

# Ollama (default — no API key needed)
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen2.5-ctx64k

# OpenAI (uncomment to use)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4

# Anthropic (uncomment to use)
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Groq free tier (uncomment to use)
# GROQ_API_KEY=gsk_...
# GROQ_MODEL=llama-3.3-70b-versatile

# Google Gemini free tier (uncomment to use)
# GEMINI_API_KEY=...
# GEMINI_MODEL=gemini-2.0-flash

# Server
HOST=0.0.0.0
PORT=8000

# Project root (where spec-forge lives)
PROJECT_ROOT=..
